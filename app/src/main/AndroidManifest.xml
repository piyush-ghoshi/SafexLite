<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Internet permission for Firebase -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Location permissions -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- Notification permissions for Android 13+ -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Wake lock for notifications -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Vibrate permission for emergency notifications -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Foreground service permissions -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <application
        android:name=".PanicButtonApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.CampusPanicButton"
        android:hardwareAccelerated="true"
        android:largeHeap="false"
        android:usesCleartextTraffic="false"
        tools:targetApi="31">

        <!-- Firebase Cloud Messaging metadata -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_icon"
            android:resource="@drawable/ic_notification" />
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_color"
            android:resource="@color/emergency_red" />
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="emergency_alerts" />

        <!-- Firebase Analytics (optional but recommended) -->
        <meta-data
            android:name="firebase_analytics_collection_enabled"
            android:value="true" />

        <!-- Splash Screen Activity (Main Entry Point) -->
        <activity
            android:name=".activities.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.CampusPanicButton.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Login Activity -->
        <activity
            android:name=".activities.LoginActivity"
            android:exported="false"
            android:theme="@style/Theme.CampusPanicButton.NoActionBar" />


        <!-- Guard Dashboard Activity -->
        <activity
            android:name=".activities.GuardDashboardActivity"
            android:exported="false"
            android:parentActivityName=".activities.LoginActivity" />

        <!-- Admin Dashboard Activity -->
        <activity
            android:name=".activities.AdminDashboardActivity"
            android:exported="false"
            android:parentActivityName=".activities.LoginActivity" />

        <!-- Alert Details Activity -->
        <activity
            android:name=".activities.AlertDetailsActivity"
            android:exported="false"
            android:launchMode="singleTop"
            tools:ignore="AppLinkUrlError">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:scheme="campuspanic"
                      android:host="alert" />
            </intent-filter>
        </activity>

        <!-- Manual Block Selection Activity -->
        <activity
            android:name=".activities.ManualBlockSelectionActivity"
            android:exported="false"
            android:theme="@style/Theme.CampusPanicButton.NoActionBar" />

        <!-- Location Test Activity (for development/testing) -->
        <activity
            android:name=".activities.LocationTestActivity"
            android:exported="false"
            android:theme="@style/Theme.CampusPanicButton.NoActionBar" />

        <!-- Profile Activity -->
        <activity
            android:name=".activities.ProfileActivity"
            android:exported="false"
            android:theme="@style/Theme.CampusPanicButton.NoActionBar" />

        <!-- Firebase Messaging Service -->
        <service
            android:name=".services.MyFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <!-- Location Service -->
        <service
            android:name=".services.LocationService"
            android:exported="false"
            android:foregroundServiceType="location" />

        <!-- Notification Service -->
        <service
            android:name=".services.NotificationService"
            android:exported="false"
            tools:ignore="Instantiatable" />

        <!-- Alert Listener Service (Background notifications) -->
        <service
            android:name=".services.AlertListenerService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!-- Notification Action Receiver -->
        <receiver
            android:name=".receivers.NotificationActionReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.campus.panicbutton.NOTIFICATION_ACTION" />
                <action android:name="com.campus.panicbutton.ACCEPT_ALERT" />
                <action android:name="com.campus.panicbutton.RESOLVE_ALERT" />
            </intent-filter>
        </receiver>

    </application>

</manifest>